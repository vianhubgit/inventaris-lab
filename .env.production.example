# ==========================================================================
#  TEMPLATE .env UNTUK PRODUCTION (Server Lab / LAN)
#  Salin ke .env di server, lalu sesuaikan nilai bertanda <ISI...>.
#    cp .env.production.example .env && php artisan key:generate
# ==========================================================================

APP_NAME="Inventaris Lab TKJ"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
# Ganti dengan IP/host server lab, mis. http://192.168.1.10 atau http://inventaris.lab
APP_URL=http://192.168.1.10
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Di production cukup simpan log level warning ke atas.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=inventaris_lab
DB_USERNAME=inventaris
DB_PASSWORD=<ISI_PASSWORD_DATABASE_KUAT>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Aktifkan hanya bila server memakai HTTPS.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Aplikasi hanya mencatat notifikasi ke database; email tidak wajib.
# Biarkan "log" bila server tidak punya SMTP.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@lab.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
